# CRC login
oc login -u kubeadmin -p <password> https://api.crc.testing:6443 --insecure-skip-tls-verify

# --- no-operador (namespace: keycloak) ---
oc apply -f no-operador/manifests/namespace.yaml
oc create secret generic keycloak-db-secret -n keycloak --from-literal=username=testuser --from-literal=password=testpassword --dry-run=client -o yaml | oc apply -f -
oc create secret generic keycloak-admin-secret -n keycloak --from-literal=password=admin --dry-run=client -o yaml | oc apply -f -
oc apply -f no-operador/manifests/postgres.yaml
oc wait --for=condition=ready pod -l app=postgresql-db -n keycloak --timeout=300s
oc apply -f no-operador/manifests/keycloak.yaml
oc wait --for=condition=available deployment/keycloak -n keycloak --timeout=900s

# --- operador (namespace: keycloak-op) ---
oc apply -f operador/manifests/namespace.yaml
oc apply -f operador/manifests/operator.yaml
# Esperar CSV: oc get csv -n keycloak-op
oc create secret generic keycloak-db-secret -n keycloak-op --from-literal=username=testuser --from-literal=password=testpassword --dry-run=client -o yaml | oc apply -f -
oc apply -f operador/manifests/postgres.yaml
oc wait --for=condition=ready pod -l app=postgresql-db -n keycloak-op --timeout=300s
oc apply -f operador/manifests/keycloak-cr.yaml
oc apply -f operador/manifests/route.yaml
# Admin: oc get secret rhbk-kc-initial-admin -n keycloak-op

