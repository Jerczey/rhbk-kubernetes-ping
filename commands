# CRC login
oc login -u kubeadmin -p <password> https://api.crc.testing:6443 --insecure-skip-tls-verify

# --- operador + Kubernetes Ping (namespace: rhbk-kubeping) ---
oc apply -f operador/manifests/namespace.yaml
oc apply -f operador/manifests/operator.yaml
# Esperar CSV: oc get csv -n rhbk-kubeping -w
oc create secret generic keycloak-db-secret -n rhbk-kubeping \
  --from-literal=username=testuser --from-literal=password=testpassword \
  --dry-run=client -o yaml | oc apply -f -
oc apply -f operador/manifests/postgres.yaml
oc wait --for=condition=ready pod -l app=postgresql-db -n rhbk-kubeping --timeout=300s
oc apply -f operador/manifests/keycloak-cr.yaml
oc apply -f operador/manifests/route.yaml
# Esperar réplicas: oc get pods -n rhbk-kubeping -l app=keycloak -w
# Admin: oc get secret rhbk-kc-initial-admin -n rhbk-kubeping -o jsonpath='{.data.password}' | base64 -d; echo

